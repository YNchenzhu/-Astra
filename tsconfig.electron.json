{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,

    /**
     * Match vite-plugin-electron's runtime: it bundles via esbuild with
     * bundler-style resolution and allows .ts imports. Keeping tsc in sync
     * means the IDE's language service (which falls back to the inferred
     * project without this config) resolves `./agents/customAgentsWatcher`
     * exactly the way the real build does — no more ghost
     * "Cannot find module" errors on freshly-added files.
     */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting — `noUnusedLocals: true` catches dead imports (the actual
       hazard: no IPC-shape reason exists for dangling *locals/imports*),
       while `noUnusedParameters: false` keeps the latitude electron handler
       signatures need for wire-shape documentation. */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["electron", "shared", "src/data/providerRegistry.ts"],
  "exclude": ["electron/**/*.test.ts", "electron/**/*.bak"]
}
