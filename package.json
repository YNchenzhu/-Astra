{
  "name": "astra",
  "productName": "星构Astra",
  "author": {
    "name": "昆明新视野教育科技有限公司"
  },
  "private": true,
  "version": "0.5.0",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:adapter",
    "build:adapter": "node scripts/buildWechatAdapter.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "build:e2e": "node scripts/runE2eBuild.mjs",
    "test:e2e": "node scripts/runE2e.mjs",
    "test:e2e:worker": "node scripts/runE2e.mjs --tool-worker",
    "clean:electron": "node -e \"const fs=require('fs');for(const d of ['dist','dist-electron']) fs.rmSync(d,{recursive:true,force:true})\"",
    "bundled-lsp:install": "npm --prefix bundled-lsp install --omit=dev --no-audit --no-fund",
    "bundled-mcp:install": "npm --prefix bundled-mcp install --omit=dev --no-audit --no-fund",
    "assert-packaging-assets": "node scripts/assertPackagingAssets.mjs",
    "electron:dev": "vite",
    "electron:build": "npm run clean:electron && npm run bundled-lsp:install && npm run bundled-mcp:install && vite build && npm run build:adapter && npm run assert-packaging-assets && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@anthropic-ai/foundry-sdk": "^0.2.3",
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "@anthropic-ai/sdk": "^0.91.1",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@napi-rs/canvas": "^0.1.77",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "chardet": "^2.1.1",
    "chokidar": "^5.0.0",
    "docx": "^9.6.1",
    "docx-preview": "^0.3.7",
    "exceljs": "^3.4.0",
    "iconv-lite": "^0.6.3",
    "ignore": "^7.0.5",
    "jsonrepair": "^3.14.0",
    "katex": "^0.17.0",
    "lru-cache": "^11.3.5",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.53.0",
    "node-pty": "^1.1.0",
    "onnxruntime-node": "^1.24.3",
    "openai": "^6.33.0",
    "path-key": "^4.0.0",
    "pdfjs-dist": "^4.10.38",
    "pinyin-pro": "^3.28.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-window": "^1.8.11",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "simple-git": "^3.36.0",
    "turndown": "^7.2.4",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "ws": "^8.21.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yaml": "^2.9.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.14",
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4"
  }
}
