release
*.local

# Runtime data root produced by the packaged app (logs / chromium-cache / memory).
# In dev it sits next to the repo, but on Windows the OS sometimes drops a
# stray "星构Astra-data/logs" inside the repo when the app is launched from
# the workspace. Keep it out of source control.
星构Astra-data/

# Large ONNX model artifacts (either bundled or user-downloaded).
# The binaries are tracked via HF — distribute via installer, not git.
resources/embeddings/**/*.onnx
resources/embeddings/**/*.bin
resources/embeddings/**/*.safetensors

# Ephemeral git worktrees created by EnterWorktree / the worktree allocator.
# These are linked worktrees on throwaway branches; never commit them.
.claude/worktrees/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

dist-adapter

# Secrets and machine-local configuration
.env
.env.*
!.env.example
.claude/settings*.json

# Local agent configuration, memory, and transient task state
.agents/
.claude/
.cursor/
.codex/
AGENTS.md
session-memory/
.playwright-mcp/
Pole Star-data/

